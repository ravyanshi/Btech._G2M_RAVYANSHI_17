include<stdio.h>
int main()
{
    int n,i, t;
    printf("enter no of element");
    scanf("%d",&n);
    int a[n];
    for(i=0;i<n;i++)
    {
        printf("enter a[%d]element=",i);
        scanf("%d",&a[i]);
    }
    for(i=0;i<=n/2;i++)
    {
        t=a[i];
        a[i]=a[n-i-1];
        a[n-i-1]=t;
    }
        printf("reversed array/n");
        for(i=0;i<n;i++)
        {
            printf("%d /n",a[i]);
        }
        return 0;
